# -------------------------
# LLM (Groq)
# -------------------------
GROQ_API_KEY=
# Options include:
# llama-3.3-70b-versatile
# mixtral-8x7b-32768
# deepseek-r1-distill-llama-70b
GROQ_MODEL=
LLM_MAX_JSON_RETRIES=3

# -------------------------
# Research verification (external sources)
# -------------------------
# Enable/disable external verification calls for publications.
RESEARCH_VERIFY_ENABLED=0
RESEARCH_VERIFY_TIMEOUT_SECONDS=8.0
RESEARCH_VERIFY_MAX_MATCHES=3

# OpenAlex recommends providing a contact email.
OPENALEX_MAILTO=

# Optional keys (leave blank to skip those sources).
SEMANTIC_SCHOLAR_API_KEY=
SCOPUS_API_KEY=
CLARIVATE_API_KEY=

# Optional: paths to local CSV datasets you provide.
# CORE_CONF_RANKINGS_CSV=backend/data/external/core_conf_ranks.csv
# SJR_JOURNAL_RANKS_CSV=backend/data/external/sjr_journal_ranks.csv

# -------------------------
# Database (MongoDB Atlas)
# -------------------------
MONGODB_URL=
# Optional if your URI does not include a default database name.
MONGODB_DB_NAME=talash
